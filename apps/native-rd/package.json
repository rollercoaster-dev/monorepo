{
  "name": "native-rd",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "ios": "bash scripts/run-ios.sh",
    "ios:device": "IOS_DEVICE_ID=\"${IOS_DEVICE_ID:?Set IOS_DEVICE_ID}\" bash scripts/run-ios.sh",
    "ios:e2e": "EXPO_PUBLIC_E2E_MODE=true bash scripts/run-ios.sh",
    "android": "expo run:android",
    "web": "expo start --web",
    "type-check": "tsc --noEmit",
    "build": "echo 'Expo app — no build step'",
    "lint": "expo lint",
    "test": "bash scripts/jest-node.sh",
    "test:db": "bash scripts/jest-node.sh src/db/__tests__/",
    "test:ci": "bash scripts/jest-node.sh --ci",
    "test:ci:smoke": "bash scripts/jest-node.sh --listTests",
    "test:watch": "bash scripts/jest-node.sh --watch",
    "storybook:native": "sb-rn-get-stories -c .storybook && EXPO_PUBLIC_STORYBOOK_ENABLED=true bash scripts/run-ios.sh",
    "storybook:web": "storybook dev -p 6006 --config-dir .storybook-web",
    "test:e2e": "bash scripts/run-e2e.sh",
    "test:e2e:single": "maestro test",
    "logs:agent": "bash scripts/agent-logs.sh",
    "start:worktree": "bash scripts/worktree-boot.sh",
    "test:a11y": "bash scripts/a11y-audit.sh",
    "test:a11y:json": "bash scripts/a11y-audit.sh --json"
  },
  "dependencies": {
    "@evolu/common": "^7.4.1",
    "@evolu/react": "^10.4.0",
    "@evolu/react-native": "^14.3.0",
    "@react-native-async-storage/async-storage": "3.0.2",
    "@react-navigation/bottom-tabs": "^7.12.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.14.11",
    "@rollercoaster-dev/design-tokens": "workspace:*",
    "@rollercoaster-dev/openbadges-core": "workspace:*",
    "@storybook/addon-ondevice-actions": "^10.3.1",
    "@storybook/addon-ondevice-controls": "^10.3.1",
    "@storybook/react-native": "^10.3.1",
    "buffer": "^6.0.3",
    "expo": "~55.0.17",
    "expo-audio": "~55.0.14",
    "expo-camera": "~55.0.16",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.17",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image-picker": "~55.0.19",
    "expo-secure-store": "~55.0.13",
    "expo-sharing": "~55.0.18",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-video": "~55.0.15",
    "openbadges-types": "workspace:*",
    "phosphor-react-native": "^3.0.3",
    "png-chunks-encode": "^1.0.0",
    "png-chunks-extract": "^1.0.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-native": "0.85.2",
    "react-native-edge-to-edge": "^1.7.0",
    "react-native-gesture-handler": ">=2.31.1",
    "react-native-keyboard-controller": "^1.21.6",
    "react-native-nitro-modules": "^0.35.5",
    "react-native-quick-crypto": "1.0.19",
    "react-native-reanimated": "~4.3.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-svg": "15.15.4",
    "react-native-unistyles": "^3.2.3",
    "react-native-view-shot": "^4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "~0.8.1",
    "set.prototype.difference": "^1.1.7",
    "set.prototype.intersection": "^1.1.8",
    "set.prototype.isdisjointfrom": "^1.1.5",
    "set.prototype.issubsetof": "^1.1.4",
    "set.prototype.issupersetof": "^1.1.3",
    "set.prototype.symmetricdifference": "^1.1.3",
    "set.prototype.union": "^1.1.3"
