{
  "name": "native-rd",
  "version": "0.1.3",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "ios": "bash scripts/run-ios.sh",
    "ios:device": "IOS_DEVICE_ID=\"${IOS_DEVICE_ID:?Set IOS_DEVICE_ID}\" bash scripts/run-ios.sh",
    "ios:e2e": "EXPO_PUBLIC_E2E_MODE=true bash scripts/run-ios.sh",
    "android": "expo run:android",
    "web": "expo start --web",
    "type-check": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "build": "echo 'Expo app — no build step'",
    "lint": "expo lint",
    "test": "bash scripts/jest-node.sh",
    "test:db": "bash scripts/jest-node.sh src/db/__tests__/",
    "test:ci": "bash scripts/jest-node.sh --ci",
    "test:ci:smoke": "bash scripts/jest-node.sh --listTests",
    "test:watch": "bash scripts/jest-node.sh --watch",
    "storybook:native": "sb-rn-get-stories -c .storybook && EXPO_PUBLIC_STORYBOOK_ENABLED=true bash scripts/run-ios.sh",
    "storybook:web": "storybook dev -p 6006 --config-dir .storybook-web",
    "test:e2e": "bash scripts/run-e2e.sh",
    "test:e2e:single": "maestro test",
    "logs:agent": "bash scripts/agent-logs.sh",
    "start:worktree": "bash scripts/worktree-boot.sh",
    "test:a11y": "bash scripts/a11y-audit.sh",
    "test:a11y:json": "bash scripts/a11y-audit.sh --json"
  },
  "dependencies": {
    "@evolu/common": "^7.4.1",
    "@evolu/react": "^10.4.0",
    "@evolu/react-native": "^14.3.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/bottom-tabs": "^7.12.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.12.0",
    "@rollercoaster-dev/design-tokens": "workspace:*",
    "@rollercoaster-dev/openbadges-core": "workspace:*",
    "@storybook/addon-ondevice-actions": "^10.2.1",
    "@storybook/addon-ondevice-controls": "^10.2.1",
    "@storybook/react-native": "^10.2.1",
    "buffer": "^5.7.1",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-camera": "~17.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-video": "~3.0.15",
    "openbadges-types": "workspace:*",
    "phosphor-react-native": "^3.0.3",
    "png-chunks-encode": "^1.0.0",
    "png-chunks-extract": "^1.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-edge-to-edge": "^1.7.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-nitro-modules": "^0.33.5",
    "react-native-quick-crypto": "1.0.12",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-unistyles": "^3.0.0",
    "react-native-view-shot": "^4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "set.prototype.difference": "^1.1.7",
    "set.prototype.intersection": "^1.1.8",
    "set.prototype.isdisjointfrom": "^1.1.5",
    "set.prototype.issubsetof": "^1.1.4",
    "set.prototype.issupersetof": "^1.1.3",
    "set.prototype.symmetricdifference": "^1.1.3",
    "set.prototype.union": "^1.1.3"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/plugin-transform-dynamic-import": "^7.27.1",
    "@babel/plugin-transform-explicit-resource-management": "^7.28.6",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/runtime": "7.29.2",
    "@storybook/react": "^10.3.6",
    "@storybook/react-native-web-vite": "^10.3.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "babel-jest": "^30.2.0",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "jest": "^30.2.0",
    "jest-expo": "^54.0.17",
    "react-test-renderer": "19.1.0",
    "storybook": "10.3.6",
    "typescript": "~6.0.3"
  },
  "expo": {
    "install": {
      "exclude": [
        "@types/jest",
        "jest",
        "typescript"
      ]
    }
  }
}
