      },
      "signature": "function deepMerge<T extends object>(base: T, overrides: Partial<T>): T {\n  const result = { ...base };\n  for (const key in overrides) {\n    const value = overrides[key];\n    if (value !== undefined) {\n      if (\n        typeof value === 'object' &&\n        value !== null &&\n        !Array.isArray(value) &&\n        typeof result[key] === 'object' &&\n        result[key] !== null\n      ) {\n        result[key] = deepMerge(\n          result[key] as object,\n          value as object\n        ) as T[typeof key];\n      } else {\n        result[key] = value as T[typeof key];\n      }\n    }\n  }\n  return result;\n}"
    },
