      "signature": "export function parseThemeName(themeName: ThemeName): {\n  colorMode: ColorMode;\n  variant: Variant;\n} {\n  const [colorMode, variant] = themeName.split('-') as [ColorMode, Variant];\n  return { colorMode, variant };\n}"
